+/// Returns true if N42_SKIP_STATE_ROOT=1 is set (cached, read once at startup).
+/// Used for benchmark testing to measure throughput without state root overhead.
+#[cfg(feature = "std")]
+pub fn n42_skip_state_root() -> bool {
